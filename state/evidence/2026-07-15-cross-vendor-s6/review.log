{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Harness defaults. Hooks default to Windows PowerShell (powershell.exe, .ps1) for this machine; /harness-init 
swaps the commands to the .sh mirror on Linux/macOS (and to 'pwsh' if you standardize on PowerShell 7). /harness-init also 
APPENDS the project's gate commands (e.g. Bash(pnpm test:*)) to permissions.allow ├óÔé¼ÔÇØ in headless -p runs nobody 
answers prompts, so a non-allowlisted Bash call is auto-denied and the agent can't run the verification gate. Personal 
overrides belong in settings.local.json (gitignored). The `model` key mirrors harness.config.json models.session (declared 
routing table; /harness-doctor checks agreement).",
  "_security_note": "We intentionally do NOT deny Edit/Write of harness.config.json, .claude/**, or specs/** here, because 
/harness-init, /harness-prune, and /plan legitimately write those (deny rules can't be lifted per-command). Instead: (1) 
the autonomous loop protects its gate config via a config-hash pin ├óÔé¼ÔÇØ it rolls back and stops if the config changes 
mid-iteration ├óÔé¼ÔÇØ and a ConfigChange hook freezes the settings surface for the same window; (2) DURING a loop run 
(loop.ps1/loop.sh set HARNESS_LOCK_SPECS before invoking the model) specs/ is made immutable on BOTH surfaces ├óÔé¼ÔÇØ the 
protect-specs PreToolUse hook covers Edit/Write/MultiEdit/NotebookEdit, and block-destructive covers shell-mediated writes 
(redirects/mv/rm into specs/) while still allowing reads. git reset --hard is hard-blocked by the hook (not an ask rule 
├óÔé¼ÔÇØ an ask would be dead code under an unconditional exit-2 block; if you genuinely need it, run it yourself in a 
terminal, where hooks don't apply). These hooks are best-effort denylists, NOT a sandbox ├óÔé¼ÔÇØ a determined agent can 
find a phrasing they miss. Spec/test integrity in supervised use rests on the fresh-context /review and the guardrails in 
CLAUDE.md/PROMPT.md. For unattended/auto runs, additionally run inside a sandbox/container with specs/ mounted read-only 
(there is no native Windows sandbox ├óÔé¼ÔÇØ use WSL2 or a devcontainer).",

  "model": "opus",

  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials.json)",
      "Read(./**/id_rsa)",
      "Read(./**/id_ed25519)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ],
    "ask": [
      "Bash(git push:*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File 
\"${CLAUDE_PROJECT_DIR}/.claude/hooks/block-destructive.ps1\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File 
\"${CLAUDE_PROJECT_DIR}/.claude/hooks/protect-specs.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File 
\"${CLAUDE_PROJECT_DIR}/.claude/hooks/format-and-check.ps1\"",
            "timeout": 120
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File 
\"${CLAUDE_PROJECT_DIR}/.claude/hooks/lock-config.ps1\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File 
\"${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.ps1\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}


