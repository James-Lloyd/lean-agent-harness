+  [ -n "${REMOTE_CONTAINERS:-}" ] && return 0     # VS Code dev containers
+  [ -n "${DEVCONTAINER:-}" ] && return 0          # devcontainer spec
+  [ -n "${container:-}" ] && return 0             # systemd-nspawn / podman
+  if [ -f /proc/1/cgroup ] && grep -qE 'docker|containerd|lxc|kubepods' /proc/1/cgroup 2>/dev/null; then
+    return 0
+  fi
+  return 1
+}
