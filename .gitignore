# --- Harness runtime artifacts -------------------------------------------------
# State files are committed (they ARE the memory), but transient run output is not.
harness/.runs/            # per-loop logs, transcripts, scratch
harness/.budget.json      # live token/cost accounting for the current run
*.harness.log
state/handoff.md          # regenerated each context reset; not worth versioning
.claude/settings.local.json   # personal overrides (permissions, env) — never commit

# --- Secrets -------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
**/credentials.json

# --- OS / editor ---------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# --- Add your stack's build/dep artifacts below (or let /harness-init do it) ----
# node_modules/  dist/  build/  __pycache__/  .venv/  target/  bin/  obj/
