{
  "name": "python",
  "description": "Reference profile: Python project (uv + ruff + pyright + pytest). Adjust to the repo.",

  "detect": {
    "files": ["pyproject.toml", "uv.lock", "poetry.lock", "requirements.txt", "setup.py"],
    "globs": ["**/*.py"]
  },

  "languages": ["python"],
  "packageManager": "uv",
  "runtime": "python",

  "gate": {
    "format": "uv run ruff format .",
    "lint": "uv run ruff check . --fix",
    "typecheck": "uv run pyright",
    "build": null,
    "test": "uv run pytest -q",
    "e2e": null
  },

  "commands": {
    "install": "uv sync",
    "run": "uv run python -m app"
  },

  "lsp": {
    "servers": ["pyright"]
  }
}
